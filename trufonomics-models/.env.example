# Thales API keys — copy to .env and fill in real values
# .env is gitignored; never commit real keys

# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# BLS — https://data.bls.gov/registrationEngine/
# Public registered key: 500 queries/day, subindex bulk access
BLS_API_KEY=

# EIA — https://www.eia.gov/opendata/
# Needed for granular energy (retail gasoline by region, Henry Hub)
EIA_API_KEY=

# Truflation enterprise API (when available)
TRUFLATION_API_KEY=
